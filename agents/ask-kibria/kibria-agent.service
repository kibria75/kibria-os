[Unit]
Description=Ask-Kibria AI Agent — KibriaOS built-in assistant (port 8765)
Documentation=https://github.com/kibria75/kibria-os
After=network.target
Wants=network.target

[Service]
Type=simple
User=kibria-agent
Group=kibria-agent
WorkingDirectory=/usr/lib/kibria-os/agents/ask-kibria
ExecStart=/usr/lib/kibria-os/agents/ask-kibria/venv/bin/uvicorn \
    main:app \
    --host 127.0.0.1 \
    --port 8765 \
    --workers 1 \
    --log-level info
Restart=on-failure
RestartSec=5
Environment=KIBRIA_OLLAMA_URL=http://localhost:11434
Environment=KIBRIA_MODEL=qwen3.5:9b-q4_K_M
Environment=KIBRIA_AGENT_PORT=8765
StandardOutput=journal
StandardError=journal
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes

[Install]
WantedBy=multi-user.target

# KibriaOS GNOME dconf system-wide defaults
# Drop into /etc/dconf/db/local.d/90_kibria-defaults
# Then run: dconf update

[org/gnome/desktop/background]
picture-uri='file:///usr/share/backgrounds/kibria/kibria-wallpaper.png'
picture-uri-dark='file:///usr/share/backgrounds/kibria/kibria-wallpaper.png'
picture-options='zoom'
primary-color='#0F766E'
secondary-color='#134E4A'

[org/gnome/desktop/screensaver]
picture-uri='file:///usr/share/backgrounds/kibria/kibria-wallpaper.png'
primary-color='#0F766E'

[org/gnome/desktop/interface]
color-scheme='prefer-dark'
accent-color='#0F766E'
gtk-theme='Yaru-teal-dark'
icon-theme='Yaru-teal'
cursor-theme='Yaru'
font-name='Ubuntu 11'
document-font-name='Ubuntu 11'
monospace-font-name='Ubuntu Mono 13'

[org/gnome/shell]
favorite-apps=['org.gnome.Nautilus.desktop', 'org.gnome.Terminal.desktop', 'firefox.desktop', 'org.gnome.TextEditor.desktop', 'org.gnome.Settings.desktop']
enabled-extensions=['ubuntu-dock@ubuntu.com', 'ding@rastersoft.com']

[org/gnome/shell/extensions/dash-to-dock]
dock-position='LEFT'
dash-max-icon-size=48
extend-height=false
show-mounts=false

[org/gnome/desktop/session]
idle-delay=uint32 900

[org/gnome/settings-daemon/plugins/power]
sleep-inactive-ac-timeout=3600
sleep-inactive-battery-timeout=1800

[org/gnome/desktop/peripherals/mouse]
natural-scroll=false

[org/gnome/desktop/peripherals/touchpad]
natural-scroll=true
tap-to-click=true

[org/gnome/system/location]
enabled=false
